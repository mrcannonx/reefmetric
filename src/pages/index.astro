---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { url } from '../utils/url';

const tools = [
  { name: 'Return Pump Calculator', desc: 'The real flow each pump delivers at your actual head — not the box GPH. 41 pumps, ranked.', tag: 'Calculator · Live', href: '/tools/return-pump-calculator' },
  { name: 'Protein Skimmer Sizer', desc: 'Which skimmers actually fit your tank once we derate the optimistic ratings for your bioload.', tag: 'Calculator · Live', href: '/tools/protein-skimmer-calculator' },
  { name: 'Reef Build Cost Estimator', desc: 'Itemized up-front + monthly running cost for any tank size and tier.', tag: 'Calculator · Live', href: '/tools/reef-build-cost-calculator' },
];
const clusters = [
  { name: 'Protein Skimmers', desc: 'By tank size, by budget, by real bioload rating — not guesses.', href: '/reviews/best-protein-skimmers' },
  { name: 'Return Pumps & Flow', desc: 'DC vs AC, turnover math, and real delivered flow at your head.', href: '/reviews/best-return-pumps' },
  { name: 'Salt & Consumables', desc: 'Every major salt mix ranked by true cost per mixed gallon.', href: '/reviews/best-reef-salt-mix' },
  { name: 'Controllers', desc: 'Apex vs GHL vs Hydros — what actually matters for your build.', href: '/compare/apex-vs-hydros-vs-ghl' },
  { name: 'Reef Lighting', desc: 'Only 4 of 11 popular fixtures have real PAR data behind them — ranked, plus a transparency scorecard on the rest.', href: '/reviews/best-reef-led-lighting' },
];
---
<Base>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Measured, not guessed</p>
      <h1>The reef gear authority that shows its math.</h1>
      <p class="lede">Data-driven reviews, side-by-side comparison databases, and calculators for saltwater aquarium gear — so you buy the right skimmer, pump, or light the first time.</p>
      <p style="margin-top:26px;">
        <a href={url('/tools')} class="btn">Explore the tools</a>
        <a href={url('/guides')} class="btn btn-ghost">Read the guides</a>
      </p>
    </div>
  </section>

  <section class="container">
    <p class="eyebrow" style="color:var(--brand-2)">The tools</p>
    <h2>Answers you can’t get from a listicle.</h2>
    <div class="grid cols-3" style="margin-top:26px;">
      {tools.map((t) => (t as any).href ? (
        <a class="card cardlink" href={url((t as any).href)}>
          <span class="pill">{t.tag}</span>
          <h3>{t.name}</h3>
          <p style="color:var(--muted)">{t.desc}</p>
        </a>
      ) : (
        <div class="card">
          <span class="pill">{t.tag}</span>
          <h3>{t.name}</h3>
          <p style="color:var(--muted)">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container">
    <p class="eyebrow" style="color:var(--brand-2)">Gear, organized by your tank</p>
    <h2>Start with your setup.</h2>
    <div class="grid cols-2" style="margin-top:26px;">
      {clusters.map((c) => (
        <a class="card cardlink" href={url(c.href)}>
          <h3>{c.name}</h3>
          <p style="color:var(--muted)">{c.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="container">
    <EmailCapture />
  </section>
</Base>
