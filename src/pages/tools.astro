---
import Base from '../layouts/Base.astro';
import { url } from '../utils/url';
const tools = [
  { name: 'Return Pump Calculator', desc: 'Enter your tank size, head height, and plumbing → the real flow each of 41 pumps delivers at your total dynamic head, ranked, with the math shown.', status: 'Live · Free', href: '/tools/return-pump-calculator' },
  { name: 'Protein Skimmer Size Calculator', desc: 'Enter your tank volume + bioload → which skimmers actually fit once we derate the optimistic manufacturer ratings, ranked, with footprint and price.', status: 'Live · Free', href: '/tools/protein-skimmer-calculator' },
  { name: 'Reef Tank Cost Calculator', desc: 'Itemized up-front cost + monthly running cost (electricity, salt, consumables) for any tank size and build tier.', status: 'Live · Free', href: '/tools/reef-build-cost-calculator' },
  { name: 'Salt Cost-per-Gallon Calculator', desc: 'Compare 12 reef salts by real cost per mixed gallon — not the box price — plus your actual monthly salt cost.', status: 'Live · Free', href: '/tools/salt-cost-calculator' },
  { name: 'Reef Dosing Calculator', desc: 'Alk, calcium, or magnesium — the exact dose to hit your target, split safely across days, for DIY and bottled two-parts.', status: 'Live · Free', href: '/tools/reef-dosing-calculator' },
  { name: 'Controller Comparison', desc: 'Apex vs GHL vs Hydros vs budget — every kit, price, and feature, side by side.', status: 'Live · Free', href: '/compare/apex-vs-hydros-vs-ghl' },
];
---
<Base title="Reef Tools & Calculators" description="Free calculators and comparison databases for saltwater aquarium gear — return pumps, skimmers, lighting, and full reef builds.">
  <section class="container">
    <p class="eyebrow" style="color:var(--brand-2)">Tools</p>
    <h1>Reef tools &amp; calculators.</h1>
    <p style="color:var(--muted);max-width:60ch;">The interactive data other reef sites don’t have. Built to answer the size- and setup-specific questions forums answer badly — and Google can’t summarize away.</p>
    <div class="grid cols-2" style="margin-top:26px;">
      {tools.map((t) => (t as any).href ? (
        <a class="card cardlink" href={url((t as any).href)}>
          <span class="pill">{t.status}</span>
          <h3>{t.name}</h3>
          <p style="color:var(--muted)">{t.desc}</p>
        </a>
      ) : (
        <div class="card">
          <span class="pill">{t.status}</span>
          <h3>{t.name}</h3>
          <p style="color:var(--muted)">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .cardlink { display:block; color:inherit; text-decoration:none; transition: transform .15s ease, box-shadow .15s ease; }
  .cardlink:hover { text-decoration:none; transform: translateY(-2px); box-shadow: 0 10px 30px rgba(13,27,38,.10); }
</style>
