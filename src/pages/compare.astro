---
import Base from '../layouts/Base.astro';
import CardArt from '../components/CardArt.astro';
import { url } from '../utils/url';
const comparisons = [
  {
    name: 'Apex vs HYDROS vs GHL ProfiLux',
    desc: 'The full reef controller comparison — kits and street prices, probes included vs extra, cloud fees, programming models, dosing and automated-testing ecosystems, and which controller fits which builder.',
    href: '/compare/apex-vs-hydros-vs-ghl',
    status: 'New',
    art: 'controller',
  },
  {
    name: 'Reef Octopus vs Nyos vs AquaMaxx Skimmers',
    desc: 'The skimmer brand face-off, computed — dollars per honestly-rated gallon and watts per 100 gallons, from published medium-bioload ratings, not box numbers.',
    href: '/compare/reef-octopus-vs-nyos-vs-aquamaxx',
    status: 'New',
    art: 'skimmer',
  },
  {
    name: 'Hanna vs Salifert vs Red Sea Test Kits',
    desc: 'Published accuracy and resolution specs, true cost per test, and the digital-vs-color-endpoint divide — for all five parameters reefers test.',
    href: '/reviews/best-reef-test-kits',
    status: 'New',
    art: 'testkit',
  },
  {
    name: 'DC vs AC Return Pumps',
    desc: 'Controllability, noise, efficiency, price, and the failure mode most people miss — the buying decision behind every pump pick.',
    href: '/guides/dc-vs-ac-return-pumps',
    status: 'Guide',
    art: 'pump',
  },
  {
    name: 'Reef Salt Mixes, Cost per Gallon',
    desc: 'Every major salt compared on what a mixed gallon really costs — plus growth vs natural-parameter chemistry, side by side.',
    href: '/reviews/best-reef-salt-mix',
    status: 'Data',
    art: 'salt',
  },
];
---
<Base
  title="Compare Reef Gear — Head-to-Head"
  description="Side-by-side reef equipment comparisons: Apex vs HYDROS vs GHL controllers, DC vs AC return pumps, and salt mixes by true cost per gallon."
>
  <section class="container">
    <p class="eyebrow" style="color:var(--brand-2)">Compare</p>
    <h1>Head-to-head, spec by spec.</h1>
    <p style="color:var(--muted);max-width:62ch;">The decisions reefers actually agonize over, settled with specs and prices in one table — sourced, dated, and independent of who pays commission. <a href={url('/how-we-rate')}>How we rate →</a></p>
    <div class="grid cols-2" style="margin-top:26px;">
      {comparisons.map((c) => (
        <a class="card cardlink" href={url(c.href)}>
          <CardArt kind={c.art} />
          <span class="pill">{c.status}</span>
          <h3>{c.name}</h3>
          <p style="color:var(--muted)">{c.desc}</p>
        </a>
      ))}
    </div>
    <p style="color:var(--muted);margin-top:28px;font-size:.9rem;">Looking for lighting? See <a href={url('/reviews/best-reef-led-lighting')}>Best Reef LED Lighting, ranked by verified PAR</a>.</p>
  </section>
</Base>
