  controller: `
    <rect x="86" y="32" width="40" height="40" rx="6" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <rect x="93" y="39" width="26" height="14" rx="2" fill="#eaf5f4" stroke="#0c7d7b" stroke-width="2"/>
    <g><circle cx="95" cy="62" r="2.4" fill="#12a3a0"/><circle cx="104" cy="62" r="2.4" fill="#12a3a0"/><circle cx="113" cy="62" r="2.4" fill="#ff6b4a"/></g>
    <path d="M126 52h16" stroke="#0c7d7b" stroke-width="3" stroke-linecap="round"/>
    <rect x="142" y="44" width="16" height="16" rx="3" fill="#fff" stroke="#12a3a0" stroke-width="3"/>`,
  light: `
    <rect x="90" y="24" width="60" height="14" rx="4" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <g fill="#0c7d7b"><circle cx="100" cy="31" r="2"/><circle cx="110" cy="31" r="2"/><circle cx="120" cy="31" r="2"/><circle cx="130" cy="31" r="2"/><circle cx="140" cy="31" r="2"/></g>
    <g fill="none" stroke-linecap="round">
      <path d="M104 42l-6 22" stroke="#12a3a0" stroke-width="2.5"/>
      <path d="M120 42v24" stroke="#ff6b4a" stroke-width="3"/>
      <path d="M136 42l6 22" stroke="#12a3a0" stroke-width="2.5"/>
    </g>`,
  doser: `
    <rect x="90" y="34" width="38" height="34" rx="6" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <circle cx="109" cy="51" r="9" fill="none" stroke="#0c7d7b" stroke-width="3"/>
    <circle cx="109" cy="51" r="2" fill="#0c7d7b"/>
    <path d="M128 44h18M128 51h18M128 58h18" stroke="#12a3a0" stroke-width="2.5" stroke-linecap="round"/>
    <path d="M150 58c4 5 4 9 0 11c-4-2-4-6 0-11z" fill="#ff6b4a"/>`,
  wavemaker: `
    <circle cx="104" cy="52" r="18" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <circle cx="104" cy="52" r="8" fill="none" stroke="#0c7d7b" stroke-width="3"/>
    <circle cx="104" cy="52" r="2.4" fill="#0c7d7b"/>
    <g fill="none" stroke-linecap="round">
      <path d="M128 44a10 10 0 0 1 0 16" stroke="#12a3a0" stroke-width="3"/>
      <path d="M137 38a18 18 0 0 1 0 28" stroke="#ff6b4a" stroke-width="3"/>
      <path d="M146 33a26 26 0 0 1 0 38" stroke="#12a3a0" stroke-width="3" opacity="0.45"/>
    </g>`,
  testkit: `
    <path d="M110 24v40a7 7 0 0 0 14 0V24" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <path d="M106 24h22" stroke="#12a3a0" stroke-width="3" stroke-linecap="round"/>
    <path d="M110 50v14a7 7 0 0 0 14 0V50z" fill="#ff6b4a" opacity="0.85"/>
    <g stroke="#0c7d7b" stroke-width="2" stroke-linecap="round"><path d="M110 34h5M110 42h5"/></g>
    <g><rect x="138" y="36" width="11" height="11" rx="2" fill="#bfe4e1"/><rect x="138" y="52" width="11" height="11" rx="2" fill="#12a3a0"/></g>`,
  tank: `
    <rect x="84" y="30" width="72" height="44" rx="5" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <path d="M88 42h64" stroke="#0c7d7b" stroke-width="2.5" stroke-dasharray="4 4"/>
    <path d="M88 68h64" stroke="#12a3a0" stroke-width="3" stroke-linecap="round"/>
    <path d="M100 68q4-13 10-6q4-9 8 0q4-5 6 6" fill="none" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>`,
  heater: `
    <rect x="104" y="18" width="16" height="54" rx="8" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <rect x="107" y="12" width="10" height="8" rx="2" fill="#0c7d7b"/>
    <path d="M112 28v36" stroke="#0c7d7b" stroke-width="2" stroke-dasharray="3 3"/>
    <g fill="none" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round">
      <path d="M132 36c4 3 4 8 0 11"/><path d="M141 31c6 5 6 12 0 17"/>
    </g>`,
  'water-change': `
    <rect x="94" y="34" width="30" height="40" rx="4" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <path d="M97 50h24" stroke="#0c7d7b" stroke-width="2.5" stroke-dasharray="4 3"/>
    <path d="M136 44h13" stroke="#0c7d7b" stroke-width="3" stroke-linecap="round"/>
    <path d="M145 40l5 4-5 4" fill="none" stroke="#0c7d7b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M150 60h-13" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round"/>
    <path d="M141 56l-5 4 5 4" fill="none" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>`,
  chem: `
    <path d="M112 22h12v13l13 29a4 4 0 0 1-3.6 5.7h-30.8a4 4 0 0 1-3.6-5.7l13-29z" fill="#fff" stroke="#12a3a0" stroke-width="3" stroke-linejoin="round"/>
    <path d="M109 22h18" stroke="#12a3a0" stroke-width="3" stroke-linecap="round"/>
    <path d="M105 54l3.5-8h19l3.5 8a4 4 0 0 1-3.6 5.7h-18.8a4 4 0 0 1-3.6-5.7z" fill="#ff6b4a" opacity="0.85"/>
    <g fill="#bfe4e1"><circle cx="115" cy="48" r="2"/><circle cx="123" cy="44" r="1.6"/><circle cx="119" cy="52" r="1.6"/></g>`,
};

const fg = art[kind] ?? art['tank'];
const backdrop = `
  <rect width="240" height="96" fill="#eef7f5"/>
  <line x1="20" y1="80" x2="220" y2="80" stroke="#c9e6e2" stroke-width="2" stroke-dasharray="3 5"/>
  <path d="M40 80v5M120 80v5M200 80v5" stroke="#c9e6e2" stroke-width="2"/>`;
// Optional spec-sheet tag, top-right — reads as a data label, on-brand for "measured, not guessed".
const tag = label
  ? `<text x="224" y="26" text-anchor="end" font-family="'Space Grotesk',system-ui,sans-serif" font-weight="700" font-size="16" letter-spacing="-0.5" fill="#0c7d7b">${label}</text>`
  : '';
---
{bare ? (
  <svg class="card-art-bare" viewBox="0 0 240 96" role="img" aria-hidden="true" set:html={fg + tag}></svg>
) : (
  <div class="card-art" aria-hidden="true">
    <svg viewBox="0 0 240 96" role="img" set:html={backdrop + fg + tag}></svg>
  </div>
)}
