    <circle cx="118" cy="69" r="2.6" fill="#ff6b4a"/>
    <path d="M130 60h14" stroke="#0c7d7b" stroke-width="3" stroke-linecap="round"/>`,
  salt: `
    <path d="M98 34h44l-5 40h-34z" fill="#fff" stroke="#12a3a0" stroke-width="3" stroke-linejoin="round"/>
    <rect x="93" y="27" width="54" height="9" rx="4" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <path d="M104 27a16 12 0 0 1 32 0" fill="none" stroke="#0c7d7b" stroke-width="3"/>
    <g fill="#ff6b4a"><circle cx="116" cy="50" r="2"/><circle cx="124" cy="56" r="2"/><circle cx="120" cy="63" r="2"/></g>
