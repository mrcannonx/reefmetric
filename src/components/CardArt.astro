    <g fill="#bfe4e1"><circle cx="108" cy="62" r="2.4"/><circle cx="116" cy="56" r="2"/><circle cx="112" cy="50" r="2.2"/></g>
    <path d="M140 24v52" stroke="#0c7d7b" stroke-width="2.5" stroke-linecap="round"/>
    <g stroke="#0c7d7b" stroke-width="2"><path d="M140 32h7M140 44h7M140 56h7M140 68h7"/></g>
    <path d="M134 44l6 6-6 6" fill="none" stroke="#ff6b4a" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"/>`,
  'calc-cost': `
    <path d="M96 22h32v50l-4-3-4 3-4-3-4 3-4-3-4 3-4-3z" fill="#fff" stroke="#12a3a0" stroke-width="3" stroke-linejoin="round"/>
    <g stroke="#cfe6e4" stroke-width="3" stroke-linecap="round"><path d="M103 33h18M103 41h18M103 49h12"/></g>
    <path d="M103 58h18" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round"/>
    <g fill="#fff" stroke="#12a3a0" stroke-width="3">
      <ellipse cx="150" cy="66" rx="13" ry="5"/><ellipse cx="150" cy="58" rx="13" ry="5"/><ellipse cx="150" cy="50" rx="13" ry="5"/>
    </g>`,

  // ---- Category cards: device diagrams ----
  pump: `
    <circle cx="112" cy="52" r="21" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <circle cx="112" cy="52" r="6" fill="none" stroke="#0c7d7b" stroke-width="3"/>
    <path d="M112 52 112 37M112 52 124.8 59.5M112 52 99.2 59.5" stroke="#0c7d7b" stroke-width="2.4" stroke-linecap="round"/>
    <path d="M112 31v-9h18" fill="none" stroke="#12a3a0" stroke-width="3" stroke-linejoin="round"/>
