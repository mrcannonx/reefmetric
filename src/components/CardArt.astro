---
// CardArt — a family of hand-drawn diagram thumbnails for the home cards.
// Deliberately NOT AI raster art or stock photos: this brand ("shows its math") reads as
// instrument diagrams, not a listicle. Inline SVG = crisp at any DPI, zero network weight,
// themed to the palette tokens, and consistent by construction.
//
// Family motif (shared by every kind): flat teal-tint panel + a dashed measurement baseline
// + teal linework + exactly ONE coral accent = the "measured" highlight.
// Tool cards use a plotted/instrument treatment (reinforces "calculated"); category cards
// use a device diagram. Colors are hard-coded to match src/styles/global.css tokens.
interface Props {
  kind: string;
  label?: string; // optional spec-sheet tag rendered top-right (e.g. a tank's gallon count)
  bare?: boolean; // foreground only, no tinted panel/baseline/wrapper — for dropping into an
                  // existing thumbnail band (e.g. the /reviews photo band as an image fallback)
}
const { kind, label, bare } = Astro.props;

// Foreground fragments, drawn on a 240×96 canvas inside the shared backdrop.
const art: Record<string, string> = {
  // ---- Tool cards: instrument / plot treatment ----
  'calc-pump': `
    <circle cx="96" cy="54" r="17" fill="#fff" stroke="#12a3a0" stroke-width="3"/>
    <circle cx="96" cy="54" r="6" fill="none" stroke="#0c7d7b" stroke-width="2.6"/>
    <path d="M96 54 96 42M96 54 106 60M96 54 86 60" stroke="#0c7d7b" stroke-width="2.2" stroke-linecap="round"/>
    <path d="M116 54h22" stroke="#0c7d7b" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="2 5"/>
    <rect x="150" y="26" width="20" height="54" rx="3" fill="#dcefec"/>
    <rect x="150" y="52" width="20" height="28" rx="3" fill="#12a3a0"/>
    <path d="M146 52h28" stroke="#ff6b4a" stroke-width="3" stroke-linecap="round"/>`,
  'calc-skimmer': `
