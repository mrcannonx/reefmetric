---
// Real email capture for the Reef Gear Cheat Sheet. POSTs to the factory API
// (exact route /v1/subscribe/reefmetric — the API stores the address and sends
// the sheet via Resend). Replaced the honest "coming soon" placeholder the moment
// both delivery and the lead magnet went live. The success state ALWAYS links the
// web version too, so a delayed/failed email never strands the subscriber.
import { url } from '../utils/url';
const SUBSCRIBE_URL = 'https://api.aiappnation.com/v1/subscribe/reefmetric';
---
<div class="capture" data-capture>
  <div data-capture-body>
    <p class="eyebrow" style="color:var(--brand-2)">Free — one email</p>
    <h2 style="margin:6px 0 0;">The Reef Gear Cheat Sheet.</h2>
    <p style="color:var(--muted);margin:8px 0 0;">The exact skimmer / pump / light picks by tank size, plus our full build-cost worksheet — as one email, no spam.</p>
    <form method="post" action={SUBSCRIBE_URL} data-capture-form>
      <input type="email" name="email" required maxlength="254" placeholder="you@example.com" aria-label="Email address" />
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;height:0;width:0;border:0;padding:0" />
      <button type="submit" class="btn">Send me the cheat sheet</button>
    </form>
    <p data-capture-msg style="display:none;color:#9a3a3a;font-size:.88rem;margin:10px 0 0;"></p>
    <p style="color:var(--muted);font-size:.78rem;margin:10px 0 0;">One email with the sheet. If we ever start a newsletter, you can opt out first. <a href={url('/privacy')}>Privacy</a></p>
  </div>
  <div data-capture-done style="display:none;">
    <p class="eyebrow" style="color:var(--brand-2)">Sent</p>
    <h2 style="margin:6px 0 0;">Check your inbox.</h2>
    <p style="color:var(--muted);margin:8px 0 0;">The cheat sheet is on its way from ReefMetric. Can't wait — or it hasn't landed in a few minutes? <a href={url('/cheat-sheet')} data-capture-link><strong>Read it right now →</strong></a></p>
  </div>
</div>

<script>
  // One hoisted script serves every instance of this component on the page.
  for (const box of document.querySelectorAll('[data-capture]')) {
    const form = box.querySelector('[data-capture-form]') as HTMLFormElement | null;
    if (!form) continue;
    const msg = box.querySelector('[data-capture-msg]') as HTMLElement;
    const body = box.querySelector('[data-capture-body]') as HTMLElement;
    const done = box.querySelector('[data-capture-done]') as HTMLElement;
    const button = form.querySelector('button') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.style.display = 'none';
      button.disabled = true;
      const label = button.textContent;
      button.textContent = 'Sending…';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
            website: (form.elements.namedItem('website') as HTMLInputElement).value,
            source: location.pathname,
          }),
        });
        if (res.status === 429) throw new Error('rate');
        if (!res.ok) throw new Error('http');
        body.style.display = 'none';
        done.style.display = 'block';
      } catch (err) {
        msg.textContent =
          (err as Error).message === 'rate'
            ? 'Too many tries from this connection — give it an hour and try again.'
            : "Couldn't reach the signup service — mind trying again in a minute?";
        msg.style.display = 'block';
        button.disabled = false;
        button.textContent = label;
      }
    });
  }
</script>
