---
// Wire the form action to Kit (ConvertKit) or Beehiiv on go-live.
// Lead magnet = the "Reef Gear Cheat Sheet" (picks by tank size + build cost worksheet).
---
<div class="capture">
  <p class="eyebrow" style="color:var(--brand-2)">Free reef build kit</p>
  <h2 style="margin:6px 0 0;">Get the Reef Gear Cheat Sheet.</h2>
  <p style="color:var(--muted);margin:8px 0 0;">The exact skimmer / pump / light picks by tank size, plus our full build-cost worksheet. One email, no spam.</p>
  <form method="post" action="#" onsubmit="return false;">
    <input type="email" name="email" placeholder="you@email.com" required aria-label="Email address" />
    <button class="btn" type="submit">Send it to me</button>
  </form>
</div>
