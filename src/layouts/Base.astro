---
import { SITE, NAV } from '../consts';
import { url } from '../utils/url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const { title, description = SITE.description, canonical } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const noindex = import.meta.env.PUBLIC_NOINDEX === 'true';
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
  </head>
  <body>
    <header class="site-header">
      <a href={url('/')} class="wordmark">Reef<span>Metric</span></a>
      <nav>
        {NAV.map((item) => <a href={url(item.href)}>{item.label}</a>)}
      </nav>
    </header>
    <div class="disclosure-bar">
      Some links are paid links — if you buy through them we may earn a commission, at no extra cost to you. <a href={url('/disclosure')}>How this works</a>.
    </div>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wordmark-sm">ReefMetric</div>
      <p>{SITE.tagline}</p>
      <nav>
        <a href={url('/about')}>About</a>
        <a href={url('/how-we-rate')}>How We Rate</a>
        <a href={url('/disclosure')}>Affiliate Disclosure</a>
        <a href={url('/privacy')}>Privacy</a>
      </nav>
      <p class="fine">© 2026 ReefMetric. Independent and reader-supported. We participate in affiliate programs and earn from qualifying purchases — it never affects our ratings.</p>
    </footer>
  </body>
</html>
